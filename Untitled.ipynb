    "arr = [*map(int, input().split())]\n",
    "print(arr)\n",
    "time = arr[0]*100+arr[1]\n",
    "a = time - 85\n",
    "ans = str(a+2400 if a<0 else a)\n",
    "m = ans[-2:]\n",
    "h = ans.split(m)\n",
    "\n",
    "print(f\"{h[0]} {m}\")\n",
    "\n"
